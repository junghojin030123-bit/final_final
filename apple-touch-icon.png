// 기존(베이스라인) 4주 예측: 최근 4주 평균 + 최근 8주 선형 추세 외삽
const baselineForecast = (sales) => {
  const recent = sales.slice(-8);
  const avg4 = sales.slice(-4).reduce((a, b) => a + b, 0) / 4;
  const slope = (recent[7] - recent[0]) / 7;
  return Array.from({ length: 4 }, (_, i) => Math.max(0, Math.round(avg4 + slope * (i + 1))));
};

// 계절 시뮬레이터가 반영된 4주 예측: 통계 기반 베이스라인에 계절 수요 배율을 곱함
// (성수기 ×1.35, 비수기 ×0.70, 평시 ×1.00) — 안전재고·유지비용뿐 아니라
// 그래프의 수요 예측선 자체가 계절에 따라 오르내리도록 하기 위함
const seasonalForecast = (product, referenceDate) => {
  const season = getSeasonInfo(product, referenceDate);
  const raw = baselineForecast(product.sales);
  return raw.map((v) => Math.max(0, Math.round(v * season.demandMultiplier)));
};

const fmt = (n) => n.toLocaleString("ko-KR");
const fmtWon = (n) => `₩${Math.round(n).toLocaleString("ko-KR")}`;
const fmtWonSigned = (n) => `${n >= 0 ? "+" : "−"}₩${Math.abs(Math.round(n)).toLocaleString("ko-KR")}`;
const hexToRgba = (hex, a) => {
  const h = hex.replace("#", "");
  const r = parseInt(h.substring(0, 2), 16), g = parseInt(h.substring(2, 4), 16), b = parseInt(h.substring(4, 6), 16);
  return `rgba(${r},${g},${b},${a})`;
};

// 백테스트: 마지막 4주를 숨기고 동일 방식으로 예측한 뒤 실제값과 비교 → MAPE(평균 절대 오차율)
const backtest = (sales) => {
  const train = sales.slice(0, -4);      // 1~22주차로 학습
  const actual = sales.slice(-4);        // 23~26주차 실제값
  const pred = baselineForecast(train);
  const rows = pred.map((p, i) => {
    const signedErr = ((p - actual[i]) / Math.max(1, actual[i])) * 100; // 양수: 과대예측, 음수: 과소예측
    return {
      week: weekLabel(22 + i),
      pred: p,
      actual: actual[i],
      err: Math.abs(signedErr),
      signedErr,
    };
  });
  const mape = rows.reduce((a, r) => a + r.err, 0) / rows.length;
  return { rows, mape };
};

// 재무 임팩트 환산: 수요 변화량(개) → 매출/리스크 금액(₩)
const financialImpact = (product, baseSum, adjSum, season) => {
  const delta = adjSum - baseSum;                       // 4주 수요 변화량
  const revenue = delta * product.price;                // 예상 매출 영향
  const margin = product.price - product.unitCost;
  const holdingRate = season ? season.holding : 0.02;
  // 미반영 시 리스크: 상향 제안 무시 → 품절 기회손실(마진 상실)
  //                  하향 제안 무시 → 과잉재고 손실(계절별 월 유지비 + 시즌오프 처분손실 10% 가정)
  const risk = delta > 0
    ? delta * margin
    : Math.abs(delta) * product.unitCost * (holdingRate + 0.10);
  return { delta, revenue, risk };
};

