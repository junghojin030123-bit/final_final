/* ------------------------- 1-0b. 계절별 재고 기준 ------------------------- */
// 소상공인 규모 가정(아래 회사 정보 카드 참고)에 맞춰, 성수기/비수기에 따라
// 안전재고 비율과 재고 유지비율을 다르게 적용합니다.
//   - 성수기: 품절 리스크가 크므로 안전재고↑, 회전이 빨라 유지비율↓
//   - 비수기: 수요가 낮아 안전재고↓, 재고가 오래 묶여 유지비율↑
//   - 평시(연중 스테디셀러): 중간값 고정
const SEASON_RATES = {
  peak: { label: "성수기", safetyStock: 0.20, holding: 0.015, demandMultiplier: 1.35 },
  off: { label: "비수기", safetyStock: 0.10, holding: 0.025, demandMultiplier: 0.70 },
  neutral: { label: "평시", safetyStock: 0.15, holding: 0.02, demandMultiplier: 1.00 },
};

const getSeasonInfo = (product, today) => {
  if (!product.peakMonths) return { key: "neutral", ...SEASON_RATES.neutral };
  const month = today.getMonth() + 1;
  const key = product.peakMonths.includes(month) ? "peak" : "off";
  return { key, ...SEASON_RATES[key] };
};

