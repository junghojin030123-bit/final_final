// 26주(약 6개월) 주간 판매량 생성 — 결정적(deterministic) 노이즈 사용
const NOISE = [3, -2, 5, -4, 1, 6, -3, 2, -5, 4, 0, -1, 7, -6, 2, 3, -2, -4, 5, 1, -3, 6, -1, 2, -5, 4];
const genSeries = (base, trend, amp, phase, nScale) =>
  Array.from({ length: 26 }, (_, i) =>
    Math.max(2, Math.round(base + trend * i + amp * Math.sin((i / 26) * Math.PI * 2 + phase) + NOISE[i] * nScale))
  );

// 주차 시작일: 2026-01-05(월) 기준. 현재 시점: 2026-07-09
const weekLabel = (i) => {
  const d = new Date(2026, 0, 5 + i * 7);
  return `${d.getMonth() + 1}/${d.getDate()}`;
};

